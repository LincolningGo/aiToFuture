# Server
PORT=4002
NODE_ENV=development
APP_BASE_URL=http://127.0.0.1:4002
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# MySQL
DB_HOST=127.0.0.1
DB_PORT=7777
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=aitofuture
DB_CONNECTION_LIMIT=10

# Storage
STORAGE_ROOT=/root/aiToFuture/storage/generated

# Provider
AI_PROVIDER=minimax_mock
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_VIDEO_MODEL=T2V-01-Director
MINIMAX_T2A_MODEL=speech-02-hd
MINIMAX_T2A_VOICE_ID=male-qn-qingse
MINIMAX_VIDEO_POLL_INTERVAL_MS=5000
MINIMAX_VIDEO_POLL_MAX_ATTEMPTS=120
GENERATION_QUEUE_CONCURRENCY=2

# Points per capability
COST_TEXT_TO_IMAGE=10
COST_IMAGE_TO_IMAGE=12
COST_TEXT_TO_VIDEO=30
COST_TEXT_TO_AUDIO=8

# Register default points
DEFAULT_REGISTER_POINTS=100
